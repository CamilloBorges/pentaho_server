# =============================================================================
# Pentaho Server CE - Docker Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Pentaho Server Configuration
# -----------------------------------------------------------------------------
# Version of Pentaho Server CE
PENTAHO_VERSION=9.4.0.0-343

# HTTP/HTTPS Ports
PENTAHO_HTTP_PORT=8080
PENTAHO_HTTPS_PORT=8443

# Nginx Reverse Proxy Ports
# Access Pentaho through Nginx on these ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# JVM Memory Settings
# Adjust based on available system RAM
PENTAHO_MIN_MEMORY=1024m
PENTAHO_MAX_MEMORY=2048m
PENTAHO_MAX_MEMORY_LIMIT=4G

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_PASSWORD=password

# Database Users
PENTAHO_USER=pentaho
PENTAHO_PASSWORD=password

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Docker network subnet (change if conflicts with existing networks)
NETWORK_SUBNET=172.28.0.0/16

# -----------------------------------------------------------------------------
# Security Notes
# -----------------------------------------------------------------------------
# ⚠️  IMPORTANT: For production use, change all default passwords!
# - POSTGRES_PASSWORD
# - PENTAHO_PASSWORD
# - Admin password (change via Pentaho web interface after first login)
